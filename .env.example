# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=r2r_coating

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_REGISTRY_URI=postgresql://postgres:your_password@localhost:5432/mlflow

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Model Configuration
MODEL_PATH=./ml/models/production
MODEL_VERSION=v1

# Data Configuration
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_FEATURES_PATH=./data/features

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Slack (선택사항 - 알림용)
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Environment
ENV=development
LOG_LEVEL=INFO
